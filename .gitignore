# ──────────────────────────────────────────────
# Root .gitignore — Smart Campus Operations Hub
# ──────────────────────────────────────────────

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Spring Boot / Maven ───────────────────────
backend/target/
backend/HELP.md
backend/.mvn/wrapper/maven-wrapper.jar
!backend/**/src/main/**/target/
!backend/**/src/test/**/target/

# Spring Tool Suite
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ── Node / Vite / React ───────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env*.local

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Secrets & Environment ─────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Uploaded files (runtime artefacts) ────────
uploads/

# ── Misc ──────────────────────────────────────
*.class
*.jar
!backend/mvnw
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
